<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:clickable="true">

    <LinearLayout
        android:id="@+id/contributor_cell"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_contributor_cell"
        android:elevation="5dp"
        android:layout_margin="20dp">

        <TextView
            android:id="@+id/contributor_name"
            android:textSize="20sp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:textStyle="bold|italic"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/contributor_role"
            android:paddingTop="10dp"
            android:textSize="12sp"
            android:textColor="?attr/colorOnPrimaryContainer"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.google.android.flexbox.FlexboxLayout
            android:id="@+id/contributor_links"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:alignItems="center"
            app:alignContent="center"
            app:justifyContent="center"
            app:flexWrap="wrap"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/contributor_github"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_button"
                android:textSize="12sp"
                android:layout_margin="2dp"
                android:visibility="gone"
                android:text="Github"/>

            <Button
                android:id="@+id/contributor_mastodon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_button"
                android:textSize="12sp"
                android:layout_margin="2dp"
                android:visibility="gone"
                android:text="Mastodon"/>

            <Button
                android:id="@+id/contributor_telegram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_button"
                android:textSize="12sp"
                android:layout_margin="2dp"
                android:visibility="gone"
                android:text="Telegram"/>

            <Button
                android:id="@+id/contributor_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_rounded_button"
                android:textSize="12sp"
                android:layout_margin="2dp"
                android:visibility="gone"
                android:text="E-Mail"/>

        </com.google.android.flexbox.FlexboxLayout>

    </LinearLayout>

</FrameLayout>

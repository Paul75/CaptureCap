<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_centerHorizontal="true">

    <LinearLayout
        android:id="@+id/statusbar"
        android:background="?attr/statusBar"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:gravity="center_horizontal"
        android:layout_centerHorizontal="true" />

    <ScrollView
        android:id="@+id/mainscroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:fillViewport="true"
        android:gravity="center">

        <LinearLayout
            android:id="@+id/mainlayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/recordingmainbutton"
                android:layout_width="250dp"
                android:layout_height="250dp"
                android:visibility="gone"
                android:contentDescription="@string/record_start"
                android:background="@drawable/icon_recording_stopped"
                android:layout_centerVertical="true"
                android:layout_centerHorizontal="true" />

            <LinearLayout
                android:id="@+id/recordpanel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true"
                android:layout_centerHorizontal="true"
                android:gravity="center_horizontal">

                <Button
                    android:id="@+id/capture_start_button"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/record_start"
                    android:drawableLeft="@drawable/icon_record_start"
                    android:text="@string/capture_start"
                    android:textColor="?attr/colorOnPrimary"
                    android:background="@drawable/bg_rounded_button"
                    android:padding="8dp"
                    android:layout_marginBottom="24dp"
                    android:layout_centerVertical="true"
                    android:layout_centerHorizontal="true" />

                <Chronometer
                    android:id="@+id/timerrecord"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_centerHorizontal="true" />

                <TextView
                    android:id="@+id/record_status_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recording_started_text"
                    android:textSize="18sp"
                    android:visibility="gone"
                    android:textColor="?attr/colorPrimary"/>

                <LinearLayout
                    android:id="@+id/record_options"
                    android:background="@drawable/bg_rounded_button"
                    android:layout_width="300dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.yepgoryo.CaptureCap.RecordOptionsButton
                        android:id="@+id/record_options_button"
                        android:background="@drawable/bg_rounded_button"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:padding="8dp">

                        <RelativeLayout
                            android:id="@+id/record_options_button_icons"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true">

                            <ImageView
                                android:id="@+id/record_options_button_icon_record"
                                android:src="@drawable/icon_record_mode"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_centerVertical="true"
                                android:layout_alignParentLeft="true" />

                            <ImageView
                                android:id="@+id/record_options_button_icon_stream"
                                android:src="@drawable/icon_record_stream"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_centerVertical="true"
                                android:layout_toRightOf="@+id/record_options_button_icon_record" />

                            <ImageView
                                android:id="@+id/record_options_button_icon_screen"
                                android:src="@drawable/icon_record_screen"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginLeft="4dp"
                                android:layout_centerVertical="true"
                                android:layout_toRightOf="@+id/record_options_button_icon_stream" />

                            <ImageView
                                android:id="@+id/record_options_button_icon_audio_playback"
                                android:src="@drawable/icon_record_audio"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginLeft="4dp"
                                android:layout_centerVertical="true"
                                android:layout_toRightOf="@+id/record_options_button_icon_screen" />

                            <ImageView
                                android:id="@+id/record_options_button_icon_microphone"
                                android:src="@drawable/icon_record_mic"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_centerVertical="true"
                                android:layout_toRightOf="@+id/record_options_button_icon_audio_playback" />

                        </RelativeLayout>

                        <TextView
                            android:id="@+id/record_options_button_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setting_record_options"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnPrimary"
                            android:layout_marginRight="10dp"
                            android:layout_centerVertical="true"
                            android:layout_alignParentRight="true"/>

                    </com.yepgoryo.CaptureCap.RecordOptionsButton>

                    <LinearLayout
                        android:id="@+id/record_options_panel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rounded_button_panel_opened"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/capture_options"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:id="@+id/button_mode_menu"
                                android:layout_width="match_parent"
                                android:gravity="center"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <com.yepgoryo.CaptureCap.CaptureSwitchModeButton
                                    android:id="@+id/button_mode_record"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:text="@string/setting_record_option_record"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="16dp"
                                    android:drawableStart="@drawable/icon_record_mode_small"
                                    android:drawablePadding="8dp"
                                    android:textSize="14sp"
                                    android:background="@drawable/bg_setting_rounded_button" />

                                <com.yepgoryo.CaptureCap.CaptureSwitchModeButton
                                    android:id="@+id/button_mode_stream"
                                    android:layout_width="wrap_content"
                                    android:layout_height="48dp"
                                    android:text="@string/setting_record_option_stream"
                                    android:paddingStart="16dp"
                                    android:paddingEnd="16dp"
                                    android:drawableStart="@drawable/icon_record_stream_small"
                                    android:drawablePadding="8dp"
                                    android:textSize="14sp"
                                    android:background="@drawable/bg_setting_rounded_button"
                                    android:layout_marginStart="8dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:layout_marginBottom="12dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:orientation="vertical">

                                <com.yepgoryo.CaptureCap.RecordSettingButton
                                    android:id="@+id/record_option_screen"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:paddingLeft="8dp"
                                    android:paddingRight="8dp">

                                    <ImageView
                                        android:id="@+id/record_options_icon_screen"
                                        android:src="@drawable/icon_record_screen"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_marginLeft="4dp"
                                        android:layout_alignParentLeft="true"
                                        android:layout_centerVertical="true" />

                                    <ImageView
                                        android:id="@+id/record_options_icon_screen_dark"
                                        android:src="@drawable/icon_record_screen_inverse"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:visibility="gone"
                                        android:layout_marginLeft="4dp"
                                        android:layout_alignParentLeft="true"
                                        android:layout_toRightOf="@+id/record_options_icon_screen"
                                        android:layout_centerVertical="true" />

                                    <TextView
                                        android:id="@+id/record_options_text_screen"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/setting_record_option_screen"
                                        android:textSize="12sp"
                                        android:textColor="?android:attr/textColorPrimary"
                                        android:layout_marginLeft="4dp"
                                        android:layout_toRightOf="@+id/record_options_icon_screen_dark"
                                        android:layout_centerVertical="true" />

                                    <androidx.appcompat.widget.SwitchCompat
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentRight="true"
                                        />

                                </com.yepgoryo.CaptureCap.RecordSettingButton>

                                <com.yepgoryo.CaptureCap.RecordSettingButton
                                    android:id="@+id/record_option_audio"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="8dp"
                                    android:paddingLeft="8dp"
                                    android:paddingRight="8dp">

                                    <ImageView
                                        android:id="@+id/record_options_icon_audio"
                                        android:src="@drawable/icon_record_audio"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_marginLeft="4dp"
                                        android:layout_alignParentLeft="true"
                                        android:layout_centerVertical="true" />

                                    <ImageView
                                        android:id="@+id/record_options_icon_audio_dark"
                                        android:src="@drawable/icon_record_audio_inverse"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:visibility="gone"
                                        android:layout_marginLeft="4dp"
                                        android:layout_alignParentLeft="true"
                                        android:layout_toRightOf="@+id/record_options_icon_audio"
                                        android:layout_centerVertical="true" />

                                    <TextView
                                        android:id="@+id/record_options_text_audio"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/setting_record_option_audio"
                                        android:textSize="12sp"
                                        android:textColor="?android:attr/textColorPrimary"
                                        android:layout_marginLeft="4dp"
                                        android:layout_toRightOf="@+id/record_options_icon_audio_dark"
                                        android:layout_centerVertical="true" />

                                    <androidx.appcompat.widget.SwitchCompat
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentRight="true"
                                        />

                                </com.yepgoryo.CaptureCap.RecordSettingButton>

                                <com.yepgoryo.CaptureCap.RecordSettingButton
                                    android:id="@+id/record_option_microphone"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:paddingLeft="8dp"
                                    android:paddingRight="8dp">

                                    <ImageView
                                        android:id="@+id/record_options_icon_microphone"
                                        android:src="@drawable/icon_record_mic"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_marginLeft="4dp"
                                        android:layout_alignParentLeft="true"
                                        android:layout_centerVertical="true" />

                                    <ImageView
                                        android:id="@+id/record_options_icon_microphone_dark"
                                        android:src="@drawable/icon_record_mic_inverse"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:visibility="gone"
                                        android:layout_toRightOf="@+id/record_options_icon_microphone"
                                        android:layout_marginLeft="4dp"
                                        android:layout_alignParentLeft="true"
                                        android:layout_centerVertical="true" />

                                    <TextView
                                        android:id="@+id/record_options_text_microphone"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/setting_record_option_microphone"
                                        android:textSize="12sp"
                                        android:layout_toRightOf="@+id/record_options_icon_microphone_dark"
                                        android:layout_marginLeft="4dp"
                                        android:textColor="?android:attr/textColorPrimary"
                                        android:layout_centerVertical="true" />

                                    <androidx.appcompat.widget.SwitchCompat
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentRight="true"
                                        />


                                </com.yepgoryo.CaptureCap.RecordSettingButton>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/record_controls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    android:gravity="center_horizontal">

                    <Button
                        android:id="@+id/record_controls_pause"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/capture_pause"
                        android:drawableLeft="@drawable/icon_record_pause"
                        android:text="@string/capture_pause"
                        android:textColor="?attr/colorOnPrimary"
                        android:background="@drawable/bg_rounded_button"
                        android:paddingLeft="24dp"
                        android:paddingRight="24dp"
                        android:drawablePadding="16dp"
                        android:layout_centerVertical="true"
                        android:layout_centerHorizontal="true" />

                    <Button
                        android:id="@+id/record_controls_resume"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/capture_resume"
                        android:drawableLeft="@drawable/icon_record_resume"
                        android:text="@string/capture_resume"
                        android:textColor="?attr/colorOnPrimary"
                        android:background="@drawable/bg_rounded_button"
                        android:paddingLeft="24dp"
                        android:paddingRight="24dp"
                        android:visibility="gone"
                        android:drawablePadding="16dp"
                        android:layout_centerVertical="true"
                        android:layout_centerHorizontal="true" />

                    <Button
                        android:id="@+id/record_controls_stop"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/capture_stop"
                        android:drawableLeft="@drawable/icon_record_stop"
                        android:layout_marginLeft="12dp"
                        android:text="@string/capture_stop"
                        android:textColor="?attr/colorOnPrimary"
                        android:background="@drawable/bg_rounded_button"
                        android:paddingLeft="24dp"
                        android:paddingRight="24dp"
                        android:drawablePadding="16dp"
                        android:layout_centerVertical="true"
                        android:layout_centerHorizontal="true" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/post_record_controls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="14dp"
                    android:visibility="gone"
                    android:gravity="center_horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp"
                        android:gravity="center_horizontal">

                        <Button
                            android:id="@+id/post_record_controls_share"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/record_share_title"
                            android:drawableLeft="@drawable/icon_record_share"
                            android:text="@string/record_share_title"
                            android:textColor="?attr/colorOnPrimary"
                            android:background="@drawable/bg_rounded_button"
                            android:paddingLeft="24dp"
                            android:paddingRight="24dp"
                            android:drawablePadding="16dp"
                            android:layout_centerVertical="true"
                            android:layout_centerHorizontal="true" />

                        <Button
                            android:id="@+id/post_record_controls_delete"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/record_delete_title"
                            android:drawableLeft="@drawable/icon_record_delete"
                            android:text="@string/record_delete_title"
                            android:textColor="?attr/colorOnPrimary"
                            android:background="@drawable/bg_rounded_button"
                            android:paddingLeft="24dp"
                            android:paddingRight="24dp"
                            android:layout_marginLeft="12dp"
                            android:drawablePadding="16dp"
                            android:layout_centerVertical="true"
                            android:layout_centerHorizontal="true" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp"
                        android:gravity="center_horizontal">

                        <Button
                            android:id="@+id/post_record_controls_open"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/record_open_title"
                            android:drawableLeft="@drawable/icon_record_play"
                            android:text="@string/record_open_title"
                            android:textColor="?attr/colorOnPrimary"
                            android:background="@drawable/bg_rounded_button"
                            android:paddingLeft="24dp"
                            android:paddingRight="24dp"
                            android:drawablePadding="16dp"
                            android:layout_centerVertical="true"
                            android:layout_centerHorizontal="true" />

                        <Button
                            android:id="@+id/post_record_controls_crop"
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/record_crop_title"
                            android:drawableLeft="@drawable/icon_record_crop"
                            android:text="@string/record_crop_title"
                            android:textColor="?attr/colorOnPrimary"
                            android:background="@drawable/bg_rounded_button"
                            android:paddingLeft="24dp"
                            android:paddingRight="24dp"
                            android:layout_marginLeft="12dp"
                            android:drawablePadding="16dp"
                            android:layout_centerVertical="true"
                            android:layout_centerHorizontal="true" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/post_record_controls_back"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/record_back_title"
                        android:drawableLeft="@drawable/icon_back_arrow"
                        android:layout_marginTop="18dp"
                        android:text="@string/record_back_title"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnPrimary"
                        android:background="@drawable/bg_rounded_button"
                        android:paddingLeft="18dp"
                        android:paddingRight="18dp"
                        android:layout_centerVertical="true"
                        android:layout_centerHorizontal="true" />

                </LinearLayout>

                <TextView
                    android:id="@+id/audioplaybackunavailable"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="center"
                    android:visibility="gone"
                    android:text="@string/audio_playback_unavailable"
                    android:layout_centerHorizontal="true" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <FrameLayout
        android:id="@+id/optionspanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="48dp"
        android:layout_gravity="end|bottom">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/openinfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="7dp"
                android:padding="12dp"
                android:src="@drawable/icon_record_info"
                android:contentDescription="@string/info_title"
                android:background="@drawable/bg_setting_rounded_button"
                android:layout_centerHorizontal="true" />

            <ImageButton
                android:id="@+id/opensettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="7dp"
                android:src="@drawable/icon_record_settings"
                android:padding="12dp"
                android:contentDescription="@string/settings_title"
                android:background="@drawable/bg_setting_rounded_button"
                android:layout_centerHorizontal="true" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
